---
import Base from "@/layouts/Base.astro";
import { getCollectionCTM } from "@/lib/contentParser.astro";
import { getEntryRouteParam } from "@/lib/utils/i18nUtils";
import { render } from "astro:content";
import OptimizedImage from "@/components/utilities/OptimizedImage.astro";
import ContactSection from "@/components/sections/ContactSection.astro";
import PageHeader from "@/layouts/components/widgets/PageHeader.astro";

export async function getStaticPaths() {
  const formaciones = await getCollectionCTM("formacion", "es");
  return formaciones.map((formacion) => ({
    params: {
      single: getEntryRouteParam(formacion),
    },
    props: {
      formacion,
    },
  }));
}

const { formacion } = Astro.props;
const { Content } = await render(formacion);

const formatDate = (date: Date | string | undefined) => {
  if (!date) return "";
  const d = new Date(date);
  return d.toLocaleDateString("es-ES", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
};
---

<Base {...formacion.data}>
  <PageHeader title={formacion.data.title} breadcrumbTitle="Formación" />

  <section class="section py-12">
    <div class="relative container max-w-4xl">
      <article>
        {formacion.data.image && (
          <div class="mb-8 overflow-hidden rounded-2xl aspect-[16/9]">
            <OptimizedImage
              src={formacion.data.image}
              alt={formacion.data.title}
              width={900}
              height={500}
              class="h-full w-full object-cover"
            />
          </div>
        )}
        <div class="flex items-center space-x-4 mb-6">
          <span class="text-sm font-semibold uppercase tracking-wider text-text-default/50">
            {formatDate(formacion.data.date)}
          </span>
          {formacion.data.tipoFormacion && (
            <span class={`inline-block px-3 py-1 text-xs font-semibold uppercase tracking-wider rounded-full border ${
              formacion.data.tipoFormacion.toLowerCase() === 'microcredencial'
                ? "bg-primary/10 text-primary border-primary/25" 
                : "bg-accent/10 text-accent border-accent/25"
            }`}>
              {formacion.data.tipoFormacion}
            </span>
          )}
        </div>
        <div class="prose max-w-none prose-lg text-text-default/80">
          <Content components={{ img: OptimizedImage }} />
        </div>
      </article>
      <div class="mt-12 border-t border-border-dark/10 pt-6">
        <a href="/formacion/" class="inline-flex items-center text-sm font-semibold text-primary hover:text-dark">
          &larr; Volver a toda la formación
        </a>
      </div>
    </div>
  </section>

  <ContactSection />
</Base>
