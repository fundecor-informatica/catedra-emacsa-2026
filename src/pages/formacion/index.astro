---
import Base from "@/layouts/Base.astro";
import PageHeader from "@/layouts/components/widgets/PageHeader.astro";
import { getCollectionCTM, getEntryCTM } from "@/lib/contentParser.astro";
import { getEntryRouteParam } from "@/lib/utils/i18nUtils";
import { sortByDate } from "@/lib/utils/sortFunctions";
import OptimizedImage from "@/components/utilities/OptimizedImage.astro";

const formacionIndex = await getEntryCTM("formacion", "-index", "es");
let list = await getCollectionCTM("formacion", "es");
list = sortByDate(list);

const formatDate = (date: Date | string | undefined) => {
  if (!date) return "";
  const d = new Date(date);
  return d.toLocaleDateString("es-ES", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
};
---

<Base {...formacionIndex.data}>
  <PageHeader
    title={formacionIndex.data.title}
    breadcrumbTitle={formacionIndex?.data?.breadcrumbTitle}
  />
  
  <section class="section py-8">
    <div class="container">
      <div class="max-w-3xl mb-12">
        <h2 class="text-h3 font-bold mb-4">Educación y Concienciación</h2>
        <p class="text-text-default/70 leading-relaxed">
          En la Cátedra EMACSA de la Universidad de Córdoba, promovemos la educación y capacitación en gestión sostenible del agua mediante cursos, talleres y seminarios dirigidos a estudiantes y profesionales. Nuestra oferta formativa combina innovación, investigación y casos prácticos para enfrentar los retos del ciclo integral del agua con soluciones efectivas.
        </p>
      </div>

      {
        list && list.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {list.map((item, index) => {
              const href = `/formacion/${getEntryRouteParam(item)}/`;
              const isMicrocredencial = item.data.tipoFormacion?.toLowerCase() === 'microcredencial';
              return (
                <article 
                  class="group flex flex-col overflow-hidden rounded-2xl border border-border-dark/10 bg-white transition-all hover:border-primary/20 hover:shadow-[0_10px_30px_rgba(0,0,0,0.03)]"
                  data-aos="fade-up"
                  data-aos-delay={index * 100}
                >
                  {item.data.image && (
                    <a href={href} class="relative block h-56 overflow-hidden">
                      <OptimizedImage
                        src={item.data.image}
                        alt={item.data.title}
                        width={400}
                        height={250}
                        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      />
                    </a>
                  )}
                  <div class="flex flex-1 flex-col p-6">
                    <div class="flex justify-between items-center mb-3">
                      <span class="text-xs font-semibold uppercase tracking-wider text-text-default/50">
                        {formatDate(item.data.date)}
                      </span>
                      {item.data.tipoFormacion && (
                        <span class={`inline-block px-3 py-1 text-xs font-semibold uppercase tracking-wider rounded-full border ${
                          isMicrocredencial 
                            ? "bg-primary/10 text-primary border-primary/25" 
                            : "bg-accent/10 text-accent border-accent/25"
                        }`}>
                          {item.data.tipoFormacion}
                        </span>
                      )}
                    </div>
                    <h3 class="mt-2 text-lg font-bold leading-snug transition-colors group-hover:text-primary">
                      <a href={href}>{item.data.title}</a>
                    </h3>
                    <p class="mt-3 flex-1 text-sm leading-relaxed text-text-default/70 line-clamp-3">
                      {item.data.description}
                    </p>
                    <a 
                      href={href} 
                      class="mt-5 inline-flex items-center text-sm font-semibold text-primary transition-colors hover:text-dark"
                    >
                      Ver detalles <span class="ml-1 transition-transform group-hover:translate-x-1">&rarr;</span>
                    </a>
                  </div>
                </article>
              );
            })}
          </div>
        ) : (
          <div class="text-center py-12">
            <p class="text-text-default/60">No hay cursos ni microcredenciales ofertados en este momento.</p>
          </div>
        )
      }
    </div>
  </section>
</Base>
