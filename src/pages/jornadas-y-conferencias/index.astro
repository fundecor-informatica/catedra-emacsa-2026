---
import Base from "@/layouts/Base.astro";
import PageHeader from "@/layouts/components/widgets/PageHeader.astro";
import { getCollectionCTM, getEntryCTM } from "@/lib/contentParser.astro";
import { getEntrySlugCTM, getEntryRouteParam } from "@/lib/utils/i18nUtils";
import { sortByDate } from "@/lib/utils/sortFunctions";
import OptimizedImage from "@/components/utilities/OptimizedImage.astro";

const jornadasIndex = await getEntryCTM("jornadas", "-index", "es");
let list = await getCollectionCTM("jornadas", "es");
list = sortByDate(list);

const formatDate = (date: Date | string | undefined) => {
  if (!date) return "";
  const d = new Date(date);
  return d.toLocaleDateString("es-ES", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
};
---

<Base {...jornadasIndex.data}>
  <PageHeader
    title={jornadasIndex.data.title}
    breadcrumbTitle={jornadasIndex?.data?.breadcrumbTitle}
  />
  
  <section class="section py-8">
    <div class="container">
      <div class="max-w-3xl mb-12">
        <h2 class="text-h3 font-bold mb-4">Intercambio de Conocimientos</h2>
        <p class="text-text-default/70 leading-relaxed">
          Mediante el desarrollo de programas y eventos para el intercambio de conocimientos y experiencias que contribuyan a la mejora de la gestión técnica y económica del agua.
        </p>
      </div>

      {
        list && list.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {list.map((item, index) => {
              const href = `/jornadas-y-conferencias/${getEntryRouteParam(item)}/`;
              return (
                <article 
                  class="group flex flex-col overflow-hidden rounded-2xl border border-border-dark/10 bg-white transition-all hover:border-primary/20 hover:shadow-[0_10px_30px_rgba(0,0,0,0.03)]"
                  data-aos="fade-up"
                  data-aos-delay={index * 100}
                >
                  {item.data.image && (
                    <a href={href} class="relative block h-56 overflow-hidden">
                      <OptimizedImage
                        src={item.data.image}
                        alt={item.data.title}
                        width={400}
                        height={250}
                        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      />
                    </a>
                  )}
                  <div class="flex flex-1 flex-col p-6">
                    <span class="text-xs font-semibold uppercase tracking-wider text-text-default/50">
                      {formatDate(item.data.date)}
                    </span>
                    <h3 class="mt-3 text-lg font-bold leading-snug transition-colors group-hover:text-primary">
                      <a href={href}>{item.data.title}</a>
                    </h3>
                    <p class="mt-3 flex-1 text-sm leading-relaxed text-text-default/70 line-clamp-3">
                      {item.data.description}
                    </p>
                    <a 
                      href={href} 
                      class="mt-5 inline-flex items-center text-sm font-semibold text-primary transition-colors hover:text-dark"
                    >
                      Ver detalles <span class="ml-1 transition-transform group-hover:translate-x-1">&rarr;</span>
                    </a>
                  </div>
                </article>
              );
            })}
          </div>
        ) : (
          <div class="text-center py-12">
            <p class="text-text-default/60">No hay jornadas ni conferencias publicadas en este momento.</p>
          </div>
        )
      }
    </div>
  </section>
</Base>
