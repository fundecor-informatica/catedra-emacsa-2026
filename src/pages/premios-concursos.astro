---
import Base from "@/layouts/Base.astro";
import PageHeader from "@/layouts/components/widgets/PageHeader.astro";
import ContactSection from "@/components/sections/ContactSection.astro";
---

<Base title="Premios y Concursos">
  <PageHeader title="Premios y Concursos" />

  <section class="section py-12">
    <div class="container">
      <div class="mb-12 max-w-3xl">
        <h2 class="text-h3 mb-4 font-bold">
          Convocatorias de Premios y Concursos
        </h2>
        <p class="text-text-default/70 leading-relaxed">
          La Cátedra EMACSA de la Universidad de Córdoba impulsa la innovación,
          la sostenibilidad y la investigación a través de diferentes premios y
          concursos. Estas convocatorias están dirigidas a la comunidad
          universitaria y a la sociedad en general, con el objetivo de reconocer
          talento, fomentar la creatividad y promover proyectos que aporten
          soluciones en el ámbito del agua, el medio ambiente y la gestión
          sostenible de los recursos. Aquí podrás consultar las convocatorias
          abiertas, así como las ediciones anteriores y los trabajos premiados.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-12">
        <!-- I Premio Nacional Card -->
        <div
          class="border-border-dark/10 hover:border-primary/20 rounded-2xl border bg-white p-8 shadow-[0_4px_20px_rgba(0,0,0,0.01)] transition-all hover:shadow-[0_10px_30px_rgba(0,0,0,0.03)] lg:p-10">
          <div
            class="border-border-dark/10 mb-8 flex flex-wrap items-center justify-between gap-4 border-b pb-6">
            <div class="flex-1">
              <span
                class="bg-primary/10 text-primary border-primary/20 mb-3 inline-block rounded-full border px-3 py-1 text-xs font-semibold tracking-wider uppercase">
                Convocatoria Cátedra EMACSA
              </span>
              <h3
                class="text-text-default text-xl leading-snug font-bold lg:text-2xl">
                I Premio Nacional a la Investigación y Divulgación en el sector
                del agua Cátedra EMACSA
              </h3>
            </div>
            <div
              class="bg-theme-light border-border-dark/5 self-start rounded-xl border px-4 py-2 text-right">
              <span
                class="text-text-default/50 block text-[10px] font-semibold tracking-wider uppercase">
                Fecha de publicación
              </span>
              <span class="text-text-default text-sm font-bold">
                04/09/2025
              </span>
            </div>
          </div>

          <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-12">
            <!-- Modalidades -->
            <div class="lg:col-span-7">
              <h4
                class="text-text-default mb-4 flex items-center text-lg font-bold">
                <span class="bg-primary mr-3 h-6 w-1.5 rounded-full"></span>
                Modalidades del Premio
              </h4>
              <p class="text-text-default/70 mb-6 text-sm">
                Dichos Premios constarán de tres modalidades:
              </p>

              <ul class="space-y-4">
                <li
                  class="bg-theme-light/40 border-border-dark/5 flex items-start rounded-xl border p-4">
                  <span
                    class="bg-primary/10 text-primary mr-4 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg text-sm font-bold">
                    a
                  </span>
                  <div>
                    <h5 class="text-text-default text-sm font-semibold">
                      Modalidad A
                    </h5>
                    <p class="text-text-default/70 mt-1 text-xs">
                      Artículo de investigación o técnico publicado en revistas
                      internacionales del sector.
                    </p>
                  </div>
                </li>
                <li
                  class="bg-theme-light/40 border-border-dark/5 flex items-start rounded-xl border p-4">
                  <span
                    class="bg-primary/10 text-primary mr-4 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg text-sm font-bold">
                    b
                  </span>
                  <div>
                    <h5 class="text-text-default text-sm font-semibold">
                      Modalidad B
                    </h5>
                    <p class="text-text-default/70 mt-1 text-xs">
                      Artículo de investigación o técnico publicado
                      exclusivamente en revistas nacionales del sector.
                    </p>
                  </div>
                </li>
                <li
                  class="bg-theme-light/40 border-border-dark/5 flex items-start rounded-xl border p-4">
                  <span
                    class="bg-primary/10 text-primary mr-4 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg text-sm font-bold">
                    c
                  </span>
                  <div>
                    <h5 class="text-text-default text-sm font-semibold">
                      Modalidad C
                    </h5>
                    <p class="text-text-default/70 mt-1 text-xs">
                      Trabajo de Fin de Máster defendido en la Universidad de
                      Córdoba y calificado al menos con sobresaliente.
                    </p>
                  </div>
                </li>
              </ul>
            </div>

            <!-- Documentación y Resoluciones -->
            <div
              class="bg-theme-light/30 border-border-dark/5 rounded-2xl border p-6 lg:col-span-5 lg:p-8">
              <h4
                class="text-text-default mb-6 flex items-center text-lg font-bold">
                <span class="bg-accent mr-3 h-6 w-1.5 rounded-full"></span>
                Documentos y Enlaces
              </h4>

              <div class="space-y-4">
                <a
                  href="https://www.uco.es/catedrasyaulas/catedraemacsa/wp-content/uploads/2025/09/EXTRACTO-CONVOCATORIA_Premio_Catedra_Emacsa-1.pdf"
                  class="group border-border-dark/10 hover:border-primary/30 flex items-center justify-between rounded-xl border bg-white p-4 transition-all hover:shadow-sm">
                  <div class="flex items-center space-x-3">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="text-primary h-6 w-6"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z">
                      </path>
                    </svg>
                    <span class="text-text-default text-sm font-semibold">
                      Extracto de la convocatoria
                    </span>
                  </div>
                  <span
                    class="text-primary bg-primary/10 group-hover:bg-primary rounded px-2.5 py-1 text-xs font-bold transition-colors group-hover:text-white">
                    AQUÍ &darr;
                  </span>
                </a>

                <a
                  href="https://www.uco.es/catedrasyaulas/catedraemacsa/wp-content/uploads/2026/02/Prov_Candid_Adm_Excluidas.pdf"
                  class="group border-border-dark/10 hover:border-primary/30 flex items-center justify-between rounded-xl border bg-white p-4 transition-all hover:shadow-sm">
                  <div class="col-span-10 flex items-center space-x-3">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="text-text-default/40 group-hover:text-primary h-6 w-6 flex-shrink-0 transition-colors"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z">
                      </path>
                    </svg>
                    <span
                      class="text-text-default/80 group-hover:text-text-default text-sm leading-snug transition-colors">
                      Listado provisional de solicitudes admitidas y excluidas
                    </span>
                  </div>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="text-text-default/40 group-hover:text-primary h-4 w-4 flex-shrink-0 transition-colors"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M14 5l7 7m0 0l-7 7m7-7H3">
                    </path>
                  </svg>
                </a>

                <a
                  href="https://www.uco.es/catedrasyaulas/catedraemacsa/wp-content/uploads/2026/02/LISTADO-DEF_-SOLICITUDES-ADMITIDAS-Y-EXCLUIDA_EMACSA.pdf"
                  class="group border-border-dark/10 hover:border-primary/30 flex items-center justify-between rounded-xl border bg-white p-4 transition-all hover:shadow-sm">
                  <div class="flex items-center space-x-3">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="text-text-default/40 group-hover:text-primary h-6 w-6 flex-shrink-0 transition-colors"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z">
                      </path>
                    </svg>
                    <span
                      class="text-text-default/80 group-hover:text-text-default text-sm leading-snug transition-colors">
                      Listado definitivo de solicitudes admitidas y excluidas
                    </span>
                  </div>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="text-text-default/40 group-hover:text-primary h-4 w-4 flex-shrink-0 transition-colors"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M14 5l7 7m0 0l-7 7m7-7H3">
                    </path>
                  </svg>
                </a>

                <a
                  href="https://www.uco.es/catedrasyaulas/catedraemacsa/wp-content/uploads/2026/03/3-Pro_Prov_Emacsa_.pdf"
                  class="group border-border-dark/10 hover:border-primary/30 flex items-center justify-between rounded-xl border bg-white p-4 transition-all hover:shadow-sm">
                  <div class="flex items-center space-x-3">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="text-text-default/40 group-hover:text-primary h-6 w-6 flex-shrink-0 transition-colors"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z">
                      </path>
                    </svg>
                    <span
                      class="text-text-default/80 group-hover:text-text-default text-sm leading-snug transition-colors">
                      Resolución provisional de concesión del I Premio Nacional
                    </span>
                  </div>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="text-text-default/40 group-hover:text-primary h-4 w-4 flex-shrink-0 transition-colors"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M14 5l7 7m0 0l-7 7m7-7H3">
                    </path>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ContactSection />
</Base>
